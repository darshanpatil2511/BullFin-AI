# ============================================================
# apps/web — environment template
# Copy to `.env.local` and fill in values. Never commit .env files.
# Vite exposes ONLY variables prefixed with `VITE_` to client code.
# ============================================================

# Supabase (public/anon — safe to ship to the browser)
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# API gateway base URL (Express server)
VITE_API_URL=http://localhost:4000

# Optional — for analytics in prod
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Optional — error monitoring
VITE_SENTRY_DSN=
