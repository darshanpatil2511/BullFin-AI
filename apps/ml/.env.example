# ============================================================
# apps/ml — environment template (FastAPI ML engine)
# Copy to `.env` and fill in values. Never commit .env files.
# ============================================================

ENV=development
LOG_LEVEL=info
PORT=5000

# Redis for caching yfinance price data (Upstash in production)
REDIS_URL=

# Default benchmark for Beta / alpha calculations
DEFAULT_BENCHMARK=SPY

# Default risk-free rate source. If unset, the engine fetches the current
# 10-year Treasury yield (^TNX) from yfinance.
RISK_FREE_RATE=

# Optional: pin a specific risk-free rate (annualized decimal, e.g. 0.045)

# Sentry for ML-engine error monitoring (optional)
SENTRY_DSN=
