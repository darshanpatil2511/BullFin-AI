# ============================================================
# apps/api — environment template (Express gateway, server-only)
# Copy to `.env` and fill in values. Never commit .env files.
# ============================================================

NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# ---- Supabase (service role key is server-only — NEVER expose to browser) ----
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-SERVER-ONLY

# ---- Google Gemini (AI advisor, insight generation) ----
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# ---- Downstream services ----
ML_ENGINE_URL=http://127.0.0.1:5000

# ---- CORS (allow the Vite dev server) ----
CLIENT_ORIGIN=http://localhost:5173

# ---- Optional: Redis for caching (Upstash in production) ----
REDIS_URL=

# ---- Optional: Sentry for error monitoring ----
SENTRY_DSN=
