# ============================================================
# BullFin-AI — root environment template
# ============================================================
# Copy this file to `.env` and fill in real values.
# Each app also has its own .env.example with app-specific vars.
# Never commit .env files to git.

# ------------------------------------------------------------
# Supabase (shared by web + api) — https://supabase.com
# ------------------------------------------------------------
# Create a project at https://supabase.com/dashboard, then find these in
# Project Settings > API.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-SERVER-ONLY

# Direct Postgres connection (for migrations via Supabase CLI or psql)
SUPABASE_DB_URL=postgresql://postgres:YOUR-DB-PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres

# ------------------------------------------------------------
# Google Gemini (AI advisor, insight generation, news sentiment)
# ------------------------------------------------------------
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# ------------------------------------------------------------
# Redis cache (Upstash free tier) — used by ML engine to cache yfinance
# ------------------------------------------------------------
# Create a free Redis DB at https://upstash.com
REDIS_URL=redis://default:PASSWORD@HOST:PORT

# ------------------------------------------------------------
# Monitoring (optional — recommended for Phase 5 deploy)
# ------------------------------------------------------------
SENTRY_DSN=
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# ------------------------------------------------------------
# Service URLs (used in production deploys)
# ------------------------------------------------------------
WEB_URL=http://localhost:5173
API_URL=http://localhost:4000
ML_URL=http://localhost:5000
