# ============================================================
# BullFin-AI — monorepo .gitignore
# ============================================================

# ----- OS / editor -----
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.vscode-test

# ----- Secrets / env -----
.env
.env.*
!.env.example
*.pem
*.key

# ----- Logs -----
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ----- Node / pnpm -----
node_modules/
.pnpm-store/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
jspm_packages/
web_modules/
lib-cov
.grunt
bower_components
.lock-wscript
build/Release
.npm
.eslintcache
.stylelintcache
.node_repl_history
*.tgz
.yarn-integrity

# ----- TypeScript / build output -----
*.tsbuildinfo
dist/
build/
out/
.next/
.nuxt/
.turbo/
.svelte-kit/

# ----- Vite -----
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# ----- Caches -----
.cache/
.parcel-cache/
.temp/
.docusaurus/
.serverless/
.fusebox/
.dynamodb/
.firebase/
.tern-port
.vuepress/dist
**/.vitepress/dist
**/.vitepress/cache

# ----- Coverage / tests -----
coverage/
*.lcov
.nyc_output/
playwright-report/
test-results/

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Any directory at any depth that looks like a Python venv — catches
# accidental venvs created in odd locations (e.g. from unquoted shell
# commands like `python -m venv # the missing`).
**/bin/activate
**/pyvenv.cfg

# ----- Supabase -----
supabase/.branches/
supabase/.temp/
supabase/functions/_shared/**/deno.lock

# ----- Misc project artifacts -----
*.zip
uploads/
tmp/
tmp-*/
~$*

# Local planning / brainstorming doc — not for the public repo.
PROJECT PLAN.txt

# ----- Gatsby -----
.cache/
